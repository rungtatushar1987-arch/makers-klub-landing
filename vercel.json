{
  "framework": "vite",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/login(.*)", "dest": "/app/index.html" },
    { "src": "/home(.*)", "dest": "/app/index.html" },
    { "src": "/events(.*)", "dest": "/app/index.html" },
    { "src": "/network(.*)", "dest": "/app/index.html" },
    { "src": "/profile(.*)", "dest": "/app/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
